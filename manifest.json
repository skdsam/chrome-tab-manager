{
  "manifest_version": 3,
  "name": "One-Tab Workspace Launcher",
  "description": "Save tab workspaces, edit their links, and launch them with one click.",
  "version": "1.0.2",
  "permissions": [
    "favicon",
    "storage",
    "tabs",
    "windows"
  ],
  "action": {
    "default_title": "Workspace Launcher",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
